# Rate Limiting - 1000 requests per minute
RATE_LIMIT_WINDOW=1          # 1 minute window
RATE_LIMIT_MAX=1000          # 1000 requests per minute

# Optional: Stricter limits for specific endpoints (if your app supports it)
RATE_LIMIT_WRITE_WINDOW=1    # 1 minute for write operations
RATE_LIMIT_WRITE_MAX=200     # 200 write requests per minute
RATE_LIMIT_READ_WINDOW=1     # 1 minute for read operations
RATE_LIMIT_READ_MAX=800      # 800 read requests per minute

# API Configuration
